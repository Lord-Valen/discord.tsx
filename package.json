{
  "name": "discord.tsx",
  "description": "Create Discord.js components in JSX",
  "version": "3.0.0",
  "type": "module",
  "author": "DevAndromeda",
  "license": "MIT",
  "homepage": "https://github.com/Lord-Valen/discord.tsx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lord-Valen/discord.tsx.git"
  },
  "bugs": {
    "url": "https://github.com/Lord-Valen/discord.tsx/issues"
  },
  "keywords": [
    "tsx-discord.js",
    "discord.jsx",
    "jsx",
    "components",
    "discord-buttons",
    "react",
    "tsx"
  ],
  "types": "./out/index.d.ts",
  "exports": {
    "import": "./out/index.js",
    "require": "./out/index.cjs"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/postbuild.mjs",
    "lint": "tsc --noEmit",
    "test:babel": "node test/babel.js",
    "test:babel:build": "babel test/babel.jsx -d test",
    "test:ts": "node test/typescript.js",
    "test:ts:build": "tsc test/typescript.tsx --outDir test"
  },
  "files": [
    "out"
  ],
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.4",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@types/node": "^24.0.3",
    "discord.js": "^13.17.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "5.8.3"
  }
}